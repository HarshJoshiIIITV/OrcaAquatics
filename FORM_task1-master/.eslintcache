e.js",[],"D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\Form\\components\\index.js",[],"D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\Form\\components\\Home.js",["78"],"import React, { useEffect } from 'react'\r\nimport { connect } from 'react-redux'\r\nimport { Typography } from '@material-ui/core'\r\n\r\nexport const Home = (props) => {\r\n    const { user_data } = props\r\n    useEffect(() => {\r\n        if (!user_data.login) {\r\n            props.history.push(\"/\");\r\n        }\r\n    }, [])\r\n    return (\r\n        user_data.login ? (\r\n            <div>\r\n\r\n                <Typography align=\"center\" color=\"primary\" variant=\"h3\"  >\r\n                    Welcome Home\r\n            </Typography>\r\n                <br />\r\n                <br />\r\n                <Typography align=\"center\" color=\"secondary\" variant=\"h6\"  >\r\n                    {user_data.user.firstName}{\" \"}{user_data.user.lastName}<br />{user_data.user.email}\r\n                </Typography>\r\n\r\n            </div>) : <div />\r\n    )\r\n}\r\n\r\nconst mapStateToProps = (state) => ({\r\n    user_data: state\r\n})\r\n\r\nconst mapDispatchToProps = {\r\n\r\n}\r\n\r\nexport default connect(mapStateToProps, mapDispatchToProps)(Home)\r\n","D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\Form\\saga.js",["79","80","81","82"],"import { act } from \"react-dom/test-utils\";\r\nimport { call, put, takeEvery, takeLatest } from \"redux-saga/effects\";\r\nimport { postData } from './post_request'\r\nimport { REQUEST_API_DATA, SUCCESS, ERROR } from './redux/constants'\r\nimport { success, error } from './redux/actions'\r\nimport { make_indiaCode } from './handlers'\r\n\r\nfunction* getApiData(action) {\r\n    try {\r\n        const user = make_indiaCode(action.payload)\r\n        const data = yield call(() => postData(user));\r\n        console.log(data)\r\n        yield put(success(user));\r\n    } catch (e) {\r\n        yield put(error())\r\n    }\r\n}\r\n\r\nexport default function* mySaga() {\r\n    yield takeEvery(REQUEST_API_DATA, getApiData);\r\n}","D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\Form\\components\\Hello.js",["83","84"],"import React, { useState } from 'react'\r\nimport Container from '@material-ui/core/Container';\r\nimport { makeStyles } from '@material-ui/core/styles';\r\nimport InputLabel from '@material-ui/core/InputLabel';\r\nimport MenuItem from '@material-ui/core/MenuItem';\r\nimport Select from '@material-ui/core/Select';\r\nimport TextField from '@material-ui/core/TextField';\r\nimport FormControl from '@material-ui/core/FormControl';\r\nimport Button from '@material-ui/core/Button';\r\nimport { Typography } from '@material-ui/core'\r\n\r\n\r\nconst useStyles = makeStyles((theme) => ({\r\n    root: {\r\n        '& > *': {\r\n            margin: theme.spacing(1),\r\n            width: '50ch',\r\n        },\r\n    },\r\n    formControl: {\r\n        margin: theme.spacing(1),\r\n        minWidth: 120,\r\n    },\r\n    selectEmpty: {\r\n        marginTop: theme.spacing(2),\r\n    },\r\n    button: {\r\n        padding: '10px',\r\n        marginTop: '20px'\r\n    },\r\n    heading: {\r\n        margin: '20px'\r\n    }\r\n}));\r\n\r\n\r\nexport const Hello = (props) => {\r\n    const classes = useStyles();\r\n    const [user, setUser] = useState({ regexp: /^[0-9\\b]+$/, firstName: '', lastName: '', email: '', password: '', phone: '', country: '' })\r\n    const [error, setError] = useState({ error_name: false })\r\n\r\n    onsubmit = (e) => {\r\n        e.preventDefault()\r\n        props.getData(user);\r\n    }\r\n    if (props.user_data.login) {\r\n        props.history.push(\"/home\");\r\n    }\r\n    return (\r\n        <div>\r\n\r\n            <Container>\r\n                <Typography color=\"primary\" variant=\"h3\" className={classes.heading} >\r\n                    Form\r\n                </Typography>\r\n                <form onSubmit={() => onsubmit} className={classes.root} autoComplete=\"off\">\r\n                    <TextField error={error.error_name} helperText=\"Enter only alphabetic characters\" required onChange={(e) => {\r\n                        if (e.target.value.match(\"[A-Za-z ]{1,32}\") == e.target.value) {\r\n                            setError({ error_name: false })\r\n                        }\r\n                        else {\r\n                            setError({ error_name: true })\r\n                        }\r\n                    }} type='text' id=\"standard-basic\" label=\"First Name\" />\r\n                    <TextField inputProps={{ pattern: \"[A-Za-z ]{1,32}\", title: \"Enter alphabetic characters only\" }} onChange={(e) => setUser({ ...user, lastName: e.target.value })} type='text' id=\"standard-basic\" label=\"Last Name\" />\r\n                    <TextField inputProps={{ pattern: \"[a-z0-9._%+-]+@[a-z0-9.-]+\\.[a-z]{2,4}$\", title: \"Enter correct mail id\" }} required onChange={(e) => setUser({ ...user, email: e.target.value })} type='email' id=\"standard-basic\" label=\"Email\" />\r\n                    <TextField inputProps={{ pattern: \".{8,}\", title: \"Enter more than 8 characters\" }} required onChange={(e) => setUser({ ...user, password: e.target.value })} type='password' id=\"standard-basic\" label=\"Password\" />\r\n                    <TextField helperText=\"Enter only Numbers\" value={user.phone} required onChange={(e) => {\r\n                        if (e.target.value === '' || user.regexp.test(e.target.value)) {\r\n                            setUser({ ...user, phone: e.target.value })\r\n                        }\r\n                    }} type='text' id=\"standard-basic\" label=\"Phone\" />\r\n                    <FormControl className={classes.formControl}>\r\n                        <InputLabel id=\"demo-simple-select-label\">Country</InputLabel>\r\n                        <Select\r\n                            required\r\n                            labelId=\"demo-simple-select-label\"\r\n                            id=\"demo-simple-select\"\r\n                            value={user.country}\r\n                            onChange={(e) => setUser({ ...user, country: e.target.value })}\r\n                        >\r\n                            <MenuItem value=\"India\">India</MenuItem>\r\n                            <MenuItem value=\"China\">China</MenuItem>\r\n                            <MenuItem value=\"Australia\">Australia</MenuItem>\r\n                        </Select>\r\n\r\n                    </FormControl>\r\n                    <Button type=\"submit\" className={classes.button} variant=\"contained\" color=\"primary\">\r\n                        Submit\r\n                    </Button>\r\n                </form>\r\n\r\n            </Container>\r\n        </div>\r\n    )\r\n}\r\n\r\n\r\nexport default Hello\r\n","D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\Form\\redux\\actions.js",[],"D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\Form\\redux\\reducer.js",[],"D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\Form\\post_request.js",[],"D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\Form\\redux\\constants.js",[],["85","86"],"D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\Form\\handlers.js",[],"D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\Components\\Header.js",["87","88","89","90","91","92","93","94","95","96","97","98","99","100","101","102","103","104","105"],"import React, { useState } from 'react'\r\nimport Container from '@material-ui/core/Container';\r\nimport { makeStyles } from '@material-ui/core/styles';\r\nimport InputLabel from '@material-ui/core/InputLabel';\r\nimport MenuItem from '@material-ui/core/MenuItem';\r\nimport Select from '@material-ui/core/Select';\r\nimport TextField from '@material-ui/core/TextField';\r\nimport FormControl from '@material-ui/core/FormControl';\r\nimport Button from '@mater