                          <Button style={{ background:'#F47912'}}>Member login</Button>\r\n                        </Grid>\r\n                    </Grid>\r\n                </Container>\r\n            </div>\r\n            <div className={classes.navbar}>\r\n                <Container style={{display:'flex',justifyContent:'space-around'}}>\r\n                    <img src={logo} width=\"44px\" height=\"44px\" style={{paddingTop:'10px'}}/>\r\n                    <Button>Learn to swim</Button>\r\n                            <Button>Squads</Button>\r\n                            <Button>SynQuatics</Button>\r\n                            <Button>Hamiliton Sharks</Button>\r\n                            <Button>Competitions</Button>\r\n                            <Button>Locations</Button>\r\n                            <Button>Blog</Button>\r\n                            <Button>Summer</Button>\r\n\r\n                </Container>\r\n\r\n            </div>\r\n          \r\n    </div>\r\n    \r\n    )\r\n}\r\n\r\n\r\nexport default Header\r\n","D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\Components\\Footer.js",["106","107","108","109","110","111","112","113","114","115","116","117","118","119","120","121","122","123","124","125","126"],"import React, { useState } from 'react'\r\nimport Container from '@material-ui/core/Container';\r\nimport { makeStyles } from '@material-ui/core/styles';\r\nimport InputLabel from '@material-ui/core/InputLabel';\r\nimport MenuItem from '@material-ui/core/MenuItem';\r\nimport Select from '@material-ui/core/Select';\r\nimport TextField from '@material-ui/core/TextField';\r\nimport FormControl from '@material-ui/core/FormControl';\r\nimport Button from '@material-ui/core/Button';\r\nimport {Grid, Typography } from '@material-ui/core'\r\nimport logo from '../images/logo.png'\r\nimport home1 from '../images/home1.jpg'\r\nimport home2 from '../images/home2.jpg'\r\nimport home3 from '../images/home3.jpg'\r\nimport home4 from '../i