orCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"61"},{"filePath":"62","messages":"63","errorCount":0,"warningCount":19,"fixableErrorCount":0,"fixableWarningCount":0,"source":"64","usedDeprecatedRules":"32"},"D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\index.js",[],["65","66"],"D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\App.js",["67"],"import Home from './Form/components/Home'\nimport Hello from './Form/components/index'\nimport { Route, BrowserRouter } from 'react-router-dom'\nimport { Provider } from 'react-redux'\nimport store from './Form/store/store'\nimport Header from './Components/Header.js'\n// import Layout from './components/Layout'\n\nfunction App() {\n  return (\n    <div>\n      <BrowserRouter>\n        <Provider store={store}>\n          <Route exact path=\"/\" component={Header} />\n          <Route exact path=\"/home\" component={Home} />\n        </Provider>\n      </BrowserRouter>\n      {/* <Layout /> */}\n    </div>\n  );\n}\n\nexport default App;\n","D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\reportWebVitals.js",[],"D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\Form\\store\\store.js",[],"D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\Form\\components\\index.js",[],"D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\Form\\components\\Home.js",["68"],"import React, { useEffect } from 'react'\r\nimport { connect } from 'react-redux'\r\nimport { Typography } from '@material-ui/core'\r\n\r\nexport const Home = (props) => {\r\n    const { user_data } = props\r\n    useEffect(() => {\r\n        if (!user_data.login) {\r\n            props.history.push(\"/\");\r\n        }\r\n    }, [])\r\n    return (\r\n        user_data.login ? (\r\n            <div>\r\n\r\n                <Typography align=\"center\" color=\"primary\" variant=\"h3\"  >\r\n                    Welcome Home\r\n            </Typography>\r\n                <br />\r\n                <br />\r\n                <Typography align=\"center\" color=\"secondary\" variant=\"h6\"  >\r\n                    {user_data.user.firstName}{\" \"}{user_data.user.lastName}<br />{user_data.user.email}\r\n                </Typography>\r\n\r\n            </div>) : <div />\r\n    )\r\n}\r\n\r\nconst mapStateToProps = (state) => ({\r\n    user_data: state\r\n})\r\n\r\nconst mapDispatchToProps = {\r\n\r\n}\r\n\r\nexport default connect(mapStateToProps, mapDispatchToProps)(Home)\r\n","D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\Form\\saga.js",["69","70","71","72"],"import { act } from \"react-dom/test-utils\";\r\nimport { call, put, takeEvery, takeLatest } from \"redux-saga/effects\";\r\nimport { postData } from './post_request'\r\nimport { REQUEST_API_DATA, SUCCESS, ERROR } from './redux/constants'\r\nimport { success, error } from './redux/actions'\r\nimport { make_indiaCode } from './handlers'\r\n\r\nfunction* getApiData(action) {\r\n    try {\r\n        const user = make_indiaCode(action.payload)\r\n        const data = yield call(() => postData(user));\r\n        console.log(data)\r\n        yield put(success(user));\r\n    } catch (e) {\r\n        yield put(error())\r\n    }\r\n}\r\n\r\nexport default function* mySaga() {\r\n    yield takeEvery(REQUEST_API_DATA, getApiData);\r\n}","D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\Form\\components\\Hello.js",["73","74"],"import React, { useState } from 'react'\r\nimport Container from '@material-ui/core/Container';\r\nimport { makeStyles } from '@material-ui/core/styles';\r\nimport InputLabel from '@material-ui/core/InputLabel';\r\nimport MenuItem from '@material-ui/core/MenuItem';\r\nimport Select from '@material-ui/core/Select';\r\nimport TextField from '@material-ui/core/TextField';\r\nimport FormControl from '@material-ui/core/FormControl';\r\nimport Button from '@material-ui/core/Button';\r\nimport { Typography } from '@material-ui/core'\r\n\r\n\r\nconst useStyles = makeStyles((theme) => ({\r\n    root: {\r\n        '& > *': {\r\n            margin: theme.spacing(1),\r\n            width: '50ch',\r\n        },\r\n    },\r\n    formControl: {\r\n        margin: theme.spacing(1),\r\n        minWidth: 120,\r\n    },\r\n    selectEmpty: {\r\n        marginTop: theme.spacing(2),\r\n    },\r\n    button: {\r\n        padding: '10px',\r\n        marginTop: '20px'\r\n    },\r\n    heading: {\r\n        margin: '20px'\r\n    }\r\n}));\r\n\r\n\r\nexport const Hello = (props) => {\r\n    const classes = useStyles();\r\n    const [user, setUser] = useState({ regexp: /^[0-9\\b]+$/, firstName: '', lastName: '', email: '', password: '', phone: '', country: '' })\r\n    const [error, setError] = useState({ error_name: false })\r\n\r\n    onsubmit = (e) => {\r\n        e.preventDefault()\r\n        props.getData(user);\r\n    }\r\n    if (props.user_data.login) {\r\n        props.history.push(\"/home\");\r\n    }\r\n    return (\r\n        <div>\r\n\r\n            <Container>\r\n                <Typography color=\"primary\" variant=\"h3\" className={classes.heading} >\r\n                    Form\r\n                </Typography>\r\n                <form onSubmit={() => onsubmit} className={classes.root} autoComplete=\"off\">\r\n                    <TextField error={error.error_name} helperText=\"Enter only alphabetic characters\" required onChange={(e) => {\r\n                        if (e.target.value.match(\"[A-Za-z ]{1,32}\") == e.target.value) {\r\n                            setError({ error_name: false })\r\n                        }\r\n                        else {\r\n                            setError({ error_name: true })\r\n                        }\r\n                    }} type='text' id=\"standard-basic\" label=\"First Name\" />\r\n                    <TextField inputProps={{ pattern: \"[A-Za-z ]{1,32}\", title: \"Enter alphabetic characters only\" }} onChange={(e) => setUser({ ...user, lastName: e.target.value })} type='text' id=\"standard-basic\" label=\"Last Name\" />\r\n                    <TextField inputProps={{ pattern: \"[a-z0-9._%+-]+@[a-z0-9.-]+\\.[a-z]{2,4}$\", title: \"Enter correct mail id\" }} required onChange={(e) => setUser({ ...user, email: e.target.value })} type='email' id=\"standard-basic\" label=\"Email\" />\r\n                    <TextField inputProps={{ pattern: \".{8,}\", title: \"Enter more than 8 characters\" }} required onChange={(e) => setUser({ ...user, password: e.target.value })} type='password' id=\"standard-basic\" label=\"Password\" />\r\n                    <TextField helperText=\"Enter only Numbers\" value={user.phone} required onChange={(e) => {\r\n                        if (e.target.value === '' || user.regexp.test(e.target.value)) {\r\n                            setUser({ ...user, phone: e.target.value })\r\n                        }\r\n                    }} type='text' id=\"standard-basic\" label=\"Phone\" />\r\n                    <FormControl className={classes.formControl}>\r\n                        <InputLabel id=\"demo-simple-select-label\">Country</InputLabel>\r\n                        <Select\r\n                            required\r\n                            labelId=\"demo-simple-select-label\"\r\n                            id=\"demo-simple-select\"\r\n                            value={user.country}\r\n                            onChange={(e) => setUser({ ...user, country: e.target.value })}\r\n                        >\r\n                            <MenuItem value=\"India\">India</MenuItem>\r\n                            <MenuItem value=\"China\">China</MenuItem>\r\n                            <MenuItem value=\"Australia\">Australia</MenuItem>\r\n                        </Select>\r\n\r\n                    </FormControl>\r\n                    <Button type=\"submit\" className={classes.button} variant=\"contained\" color=\"primary\">\r\n                        Submit\r\n                    </Button>\r\n                </form>\r\n\r\n            </Container>\r\n        </div>\r\n    )\r\n}\r\n\r\n\r\nexport default Hello\r\n","D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\Form\\redux\\actions.js",[],"D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\Form\\redux\\reducer.js",[],"D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\Form\\post_request.js",[],"D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\Form\\redux\\constants.js",[],"D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\Form\\handlers.js",[],["75","76"],"D:\\ORCA_AQUATICS\\FORM_task1-master\\FORM_task1-master\\src\\Components\\Header.js",["77","78","79","80","81","82","83","84","85","86","87","88","89","90","91","92","93","94","95"],"import React, { useState } from 'react'\r\nimport Container from '@material-ui/core/Container';\r\nimport { makeStyles } from '@material-ui/core/styles';\r\nimport InputLabel from '@material-ui/core/InputLabel';\r\nimport MenuItem from '@material-ui/core/MenuItem';\r\nimport Select from '@material-ui/core/Select';\r\nimport TextField from '@material-ui/core/TextField';\r\nimport FormControl from '@material-ui/core/FormControl';\r\nimport Button from '@material-ui/core/Button';\r\nimport {Grid, Typography } from '@material-ui/core'\r\nimport logo from '../images/logo.png'\r\nimport home1 from '../images/home1.jpg'\r\nimport home2 from '../images/home2.jpg'\r\nimport home3 from '../images/home3.jpg'\r\nimport home4 from '../images/home4.jpg'\r\nimport Carousel from 'react-material-ui-carousel'\r\nimport { Paper} from '@mui/material'\r\nimport PhoneIcon from '@material-ui/icons/Phone';\r\nimport MailOutlineIcon from '@material-ui/icons/MailOutline';\r\nimport coropic from '../images/coropic.jpg'\r\n\r\nconst useStyles = makeStyles((theme) => ({\r\n    topheader:{\r\n        background: '#FAFAFA',\r\n        borderBottom: '1px solid #f2f2f2',\r\n        color: '#111111',\r\n        overflow: 'hidden',\r\n    // background: '#5c5c5c',\r\n    lineHeight: '48px',\r\n    // color: '#FFFFFF',\r\n    fontSize: '16px',\r\n    '& Button':{\r\n        fontFamily:'Libre Baskerville',\r\n        fontWeight:600\r\n    }\r\n    },\r\n    navbar:{\r\n        '& Button':{\r\n            fontFamily:'Libre Baskerville',\r\n            fontWeight:600\r\n        },\r\n        padding:'10px'\r\n    },\r\n    orange_buttons:{\r\n        padding:'15px 30px',\r\n        background:'#F47912',\r\n        color:'white',\r\n        borderRadius:'10px',\r\n        fontFamily:'Libre Baskerville',\r\n        fontWeight:600\r\n    },\r\n    '.MuiTypography-h2':{\r\n        color:'white'\r\n    },\r\n    courousal:{\r\n        '& .MuiTypography-h2':{\r\n            color:'white ',\r\n            fontFamily: 'Libre Baskerville'\r\n        },\r\n        '& Button':{\r\n            marginTop:'25px',\r\n        }\r\n    },\r\n    parentHeader:{\r\n        '& .MuiTypography-h4':{\r\n            fontWeight:600,\r\n            fontFamily: 'Libre Baskerville',\r\n            color:'white'\r\n        },\r\n        '& .MuiTypography-h6':{\r\n            fontWeight:600,\r\n            fontFamily: 'Libre Baskerville',\r\n            color:'white'\r\n        },\r\n        '& Button':{\r\n            fontFamily: 'Libre Baskerville',\r\n        }\r\n    },\r\n    aboutOA:{\r\n        padding:'50px 0px',\r\n        '& p':{\r\n            fontFamily: 'Libre Baskerville',\r\n            color:'#646464'\r\n        },\r\n        '& .MuiTypography-h4':{\r\n            fontWeight:400,\r\n            fontFamily: 'Libre Baskerville',\r\n            color:'#555555'\r\n        },\r\n        '& .MuiTypography-h6':{\r\n            fontWeight:400,\r\n            fontFamily: 'Libre Baskerville',\r\n            color:'#555555'\r\n        },\r\n        '& Button':{\r\n            \r\n        },\r\n        '& .MuiTypography-body2':{\r\n            padding:'10px 20px 10px 0px'\r\n        }\r\n    },\r\n    formHome:{\r\n        '& .MuiFilledInput-root':{\r\n            marginBottom:'10px',\r\n            marginTop:'10px'\r\n        },\r\n        '& .MuiFilledInput-input':{\r\n            padding:'15px'\r\n        },\r\n        '& Button':{\r\n            marginTop:'15px',\r\n            backgroundColor:'#F47912',\r\n            padding:'20px 10px',\r\n            fontWeight:600\r\n        }\r\n    },\r\n    ourProg:{\r\n        backgroundColor:'#EDF0F2',\r\n        width:'100%',\r\n        padding:'50px 0px',\r\n        '& p':{\r\n            fontFamily: 'Libre Baskerville',\r\n            color:'#555555'\r\n        },\r\n        '& .MuiTypography-h4':{\r\n            fontWeight:600,\r\n            fontFamily: 'Libre Baskerville',\r\n            color:'#111111'\r\n        },\r\n        '& .MuiTypography-h6':{\r\n            fontWeight:400,\r\n            fontFamily: 'Libre Baskerville',\r\n            color:'#555555'\r\n        },\r\n        '& Button':{\r\n            \r\n        },\r\n        '& .MuiTypography-body2':{\r\n            padding:'10px 20px 10px 0px'\r\n        }\r\n    }\r\n    \r\n}));\r\n\r\n\r\nexport const Header= (props) => {\r\n    const classes = useStyles();\r\n    return(\r\n        <div className={classes.parentHeader}>\r\n            <div className={classes.topheader}>\r\n                <Container>\r\n                    <Grid container>\r\n                        <Grid item md={5}>\r\n                            <MailOutlineIcon style={{width:'24px',height:'18px',position:'relative',top:'4px'}}/>\r\n                            <span>orcaswim22@gmail.com</span>\r\n                            <PhoneIcon style={{width:'22px',height:'16px',marginLeft:'10px',position:'relative',top:'2px'}}/>\r\n                            <span style={{marginLeft:'-4px'}}>  +919560956633</span>    \r\n                        </Grid>\r\n                        <Grid item md={7} style={{display:'flex',justifyContent:'space-around'}}> \r\n                            <Button>NewsLetter</Button>\r\n          ,                  <Button>Gallery</Button>\r\n                            <Button>Live results</Button>\r\n                            <Button style={{ background:'#F47912'}}>Member login</Button>\r\n                        </Grid>\r\n                    </Grid>\r\n                </Container>\r\n            </div>\r\n            <div className={classes.navbar}>\r\n                <Container style={{display:'flex',justifyContent:'space-around'}}>\r\n                    <img src={logo} width=\"44px\" height=\"44px\" style={{paddingTop:'10px'}}/>\r\n                    <Button>Learn to swim</Button>\r\n                            <Button>Squads</Button>\r\n                            <Button>SynQuatics</Button>\r\n                            <Button>Hamiliton Sharks</Button>\r\n                            <Button>Competitions</Button>\r\n                            <Button>Locations</Button>\r\n                            <Button>Blog</Button>\r\n                            <Button>Summer</Button>\r\n\r\n                </Container>\r\n\r\n            </div>\r\n            <div >\r\n            <Carousel  className={classes.courousal} animation=\"slide\" indicators={false} interval={4000}  navButtonsAlwaysVisible={true} autoPlay={true}>\r\n                \r\n                        <Paper style={{ height: '760px' }} > \r\n                            <div style={{position:'relative'}}>\r\n                                <img src={home1} />\r\n                                <div style={{position:'absolute', top:'20%', left:'16%'}}>\r\n                                <Typography variant='h2'>IT'S NEVER TOO EARLY TO <br/>LEARN TO SWIM!</Typography>\r\n                                <Button className={classes.orange_buttons}>LEARN MORE</Button>\r\n                                </div>\r\n                            </div>\r\n                        </Paper>\r\n                        <Paper style={{ height: '760px' }}   >\r\n                        <div style={{position:'relative'}}>\r\n                                <img src={home2} />\r\n                                <div style={{position:'absolute', top:'20%', left:'16%'}}>\r\n                                <Typography variant='h2'>IT'S NEVER TOO EARLY TO <br/>LEARN TO SWIM!</Typography>\r\n                                <Button className={classes.orange_buttons}>LEARN MORE</Button>\r\n                                </div>\r\n                            </div>\r\n                         </Paper>\r\n                        <Paper  style={{ height: '760px' }} >\r\n                        <div style={{position:'relative'}}>\r\n                                <img src={home3} />\r\n                                <div style={{position:'absolute', top:'20%', left:'16%'}}>\r\n                                <Typography variant='h2'>IT'S NEVER TOO EARLY TO <br/>LEARN TO SWIM!</Typography>\r\n                                <Button className={classes.orange_buttons}>LEARN MORE</Button>\r\n                                </div>\r\n                            </div>\r\n                        </Paper>\r\n                        <Paper style={{ height: '760px' }} >\r\n                        <div style={{position:'relative'}}>\r\n                                <img src={home4} />\r\n                                <div style={{position:'absolute', top:'20%', left:'16%'}}>\r\n                                <Typography variant='h2'>IT'S NEVER TOO EARLY TO <br/>LEARN TO SWIM!</Typography>\r\n                                <Button className={classes.orange_buttons}>LEARN MORE</Button>\r\n                                </div>\r\n                            </div>\r\n                        </Paper>\r\n                        \r\n                \r\n            </Carousel>\r\n            <div style={{backgroundColor:'#F47912',padding:'50px 0px'}}>\r\n                <Container>\r\n                    <Grid container>\r\n                        <Grid item md={9}>\r\n                            <Typography variant='h4'>REGISTER NOW!</Typography>\r\n                            <br/>\r\n                            <Typography variant='h6'>Become water safe and kick start your journey with OrcaAquatics today!</Typography>\r\n                        </Grid>\r\n                        <Grid item md={3}>\r\n                            <Button style={{backgroundColor:'black',color:'white', padding:'25px 10px',borderRadius:'10px'}} fullWidth>START FREE ASSESSMENT</Button>\r\n                        </Grid>\r\n                    </Grid>\r\n                </Container>\r\n            </div>\r\n            </div>\r\n            <div className={classes.aboutOA}>\r\n                <Container>\r\n                    <Grid container>\r\n                        <Grid item md={7}>\r\n                            <br/>\r\n                            <Typography  variant='h4'>ABOUT ORCA AQUATICS</Typography>\r\n                            <br/>\r\n                            <Typography variant='body2'>\r\n                            Orca Aquatics is home of a comprehensive aquatics programme in swimming, competitive swimming, artistic swimming and water polo. With over 30 locations in the UAE,\r\n                               and UK qualified teachers and coaches to choose from, access to quality aquatics provision has never been easier.\r\n                            </Typography>\r\n                            <br/>\r\n                            <Grid container>\r\n                                <Grid item md={6}>\r\n                                <Typography variant='h6' style={{fontWeight:600}}>OVER 30+ LOCATIONS</Typography>\r\n                                <Typography variant='body2'> Be it Dubai or Abu Dhabi, one of our swimming locations is never too far. </Typography>\r\n                            \r\n                                </Grid>\r\n                                <Grid item md={6}>\r\n                                <Typography variant='h6' style={{fontWeight:600}}>STRUCTURED PATHWAY</Typography>\r\n                                <Typography variant='body2'>Our programmes follow a structured pathway that are fun and engaging whilst building water confidence.</Typography>\r\n                                    \r\n                                </Grid>\r\n                            </Grid>\r\n                            <br/>\r\n                            <Grid container>\r\n                                <Grid item md={6}>\r\n                                <Typography variant='h6' style={{fontWeight:600}}>UK QUALIFIED TEACHERS</Typography>\r\n                                <Typography variant='body2'> Highly qualified swimming and coaching staff who undergo monthly training ensuring the best delivery of our programmes.</Typography>\r\n                            \r\n                                </Grid>\r\n                                <Grid item md={6}>\r\n                                <Typography variant='h6' style={{fontWeight:600}}>ONLINE ASSESSMENT</Typography>\r\n                                <Typography variant='body2'>No need to visit our pool for an assessment. Get assessed online and complete your booking in a matter of minutes.</Typography>\r\n                                    \r\n                                </Grid>\r\n                            </Grid>\r\n\r\n                        </Grid>\r\n                        <Grid item md={5}>\r\n                            <div className={classes.formHome} style={{background: '#FFFFFF',padding: '30px 20px',border: '1px solid #f2f2f2',boxShadow: '0px 0px 25px 10px rgb(0 0 0 / 5%)'}}>\r\n                            <Typography variant='h6' style={{fontWeight:600,textAlign:'center'}}>HAVE A QUESTION? <br/> REQUEST A CALLBACK FROM OUR<br/> SUPPORT STAFF</Typography>\r\n                            \r\n                            <TextField fullWidth id=\"name\" label=\"Name\" variant=\"filled\" />\r\n                            \r\n                            <TextField fullWidth id=\"email\" label=\"Email\" variant=\"filled\" />\r\n                            \r\n                            <TextField fullWidth id=\"phone\" label=\"Phone\" variant=\"filled\" />\r\n                            \r\n                            <TextField fullWidth id=\"message\" label=\"Phone\" variant=\"filled\" />\r\n                            \r\n                            <Button fullWidth>SEND MESSAGE</Button>\r\n                            </div>\r\n\r\n\r\n                        </Grid>\r\n                    </Grid>\r\n                </Container>\r\n\r\n            </div>\r\n            <div className={classes.ourProg}>\r\n                <Container>\r\n                    <Typography align=\"center\" variant='h4'>OUR PROGRAMMERS\r\n                    </Typography>\r\n                    <br/>\r\n                    <Typography variant='body2'>\r\n                    We offer fun and competitive opportunities for you to lead a healthier and safer lifestyle. Whether you are starting your journey to learn how to swim or have Olympic aspirations in any aquatic sport, we have the programme for you. We invite you to join us and experience the difference we can make in your life through the water.\r\n                    </Typography>\r\n                    <br/>\r\n                    <Carousel  className={classes.courousal} animation=\"slide\" indicators={false} interval={4000}  navButtonsAlwaysVisible={true} autoPlay={true}>\r\n                        <div>\r\n                            <Grid container>\r\n                                <Grid item md={4} style={{padding:'20px'}}>\r\n                                    <img src={coropic} width=\"350px\" height=\"300px\"  />\r\n                                </Grid>\r\n                                <Grid item md={4} style={{padding:'20px'}}>\r\n                                    <img src={coropic} width=\"350px\" height=\"300px\"  />\r\n                                </Grid>\r\n                                <Grid item md={4} style={{padding:'20px'}}>\r\n                                    <img src={coropic} width=\"350px\" height=\"300px\" />\r\n                                </Grid>\r\n                            </Grid>\r\n\r\n                        </div>\r\n                        <div>\r\n                            <Grid container>\r\n                                <Grid item md={4} style={{padding:'20px'}}>\r\n                                    <img src={coropic} width=\"350px\" height=\"300px\"  />\r\n                                </Grid>\r\n                                <Grid item md={4} style={{padding:'20px'}}>\r\n                                    <img src={coropic} width=\"350px\" height=\"300px\"  />\r\n                                </Grid>\r\n                                <Grid item md={4} style={{padding:'20px'}}>\r\n                                    <img src={coropic} width=\"350px\" height=\"300px\" />\r\n                                </Grid>\r\n                            </Grid>\r\n\r\n                        </div>\r\n                        <div>\r\n                            <Grid container>\r\n                                <Grid item md={4} style={{padding:'20px'}} >\r\n                                    <img src={coropic} width=\"350px\" height=\"300px\"  />\r\n                                </Grid>\r\n                                <Grid item md={4} style={{padding:'20px'}} >\r\n                                    <img src={coropic} width=\"350px\" height=\"300px\"  />\r\n                                </Grid>\r\n                                <Grid item md={4} style={{padding:'20px'}} >\r\n                                    <img src={coropic} width=\"350px\" height=\"300px\" />\r\n                                </Grid>\r\n                            </Grid>\r\n\r\n                        </div>\r\n\r\n\r\n                    </Carousel>\r\n                <br/>\r\n                <Button className={classes.orange_buttons} style={{textAlign:'center'}}>\r\n                    START ASSESSMENT\r\n                </Button>\r\n                \r\n                </Container>\r\n                \r\n            </div>\r\n\r\n    </div>\r\n    \r\n    )\r\n}\r\n\r\n\r\nexport default Header\r\n",{"ruleId":"96","replacedBy":"97"},{"ruleId":"98","replacedBy":"99"},{"ruleId":"100","severity":1,"message":"101","line":2,"column":8,"nodeType":"102","messageId":"103","endLine":2,"endColumn":13},{"ruleId":"104","severity":1,"message":"105","line":11,"column":8,"nodeType":"106","endLine":11,"endColumn":10,"suggestions":"107"},{"ruleId":"100","severity":1,"message":"108","line":1,"column":10,"nodeType":"102","messageId":"103","endLine":1,"endColumn":13},{"ruleId":"100","severity":1,"message":"109","line":2,"column":32,"nodeType":"102","messageId":"103","endLine":2,"endColumn":42},{"ruleId":"100","severity":1,"message":"110","line":4,"column":28,"nodeType":"102","messageId":"103","endLine":4,"endColumn":35},{"ruleId":"100","severity":1,"message":"111","line":4,"column":37,"nodeType":"102","messageId":"103","endLine":4,"endColumn":42},{"ruleId":"112","severity":1,"message":"113","line":58,"column":69,"nodeType":"114","messageId":"115","endLine":58,"endColumn":71},{"ruleId":"116","severity":1,"message":"117","line":66,"column":82,"nodeType":"118","messageId":"119","endLine":66,"endColumn":83,"suggestions":"120"},{"ruleId":"96","replacedBy":"121"},{"ruleId":"98","replacedBy":"122"},{"ruleId":"100","severity":1,"message":"123","line":1,"column":17,"nodeType":"102","messageId":"103","endLine":1,"endColumn":25},{"ruleId":"100","severity":1,"message":"124","line":4,"column":8,"nodeType":"102","messageId":"103","endLine":4,"endColumn":18},{"ruleId":"100","severity":1,"message":"125","line":5,"column":8,"nodeType":"102","messageId":"103","endLine":5,"endColumn":16},{"ruleId":"100","severity":1,"message":"126","line":6,"colum