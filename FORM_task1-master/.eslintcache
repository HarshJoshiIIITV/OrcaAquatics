ssing dependencies: 'props.history' and 'user_data.login'. Either include them or remove the dependency array.","ArrayExpression",["133"],"'act' is defined but never used.","'takeLatest' is defined but never used.","'SUCCESS' is defined but never used.","'ERROR' is defined but never used.","eqeqeq","Expected '===' and instead saw '=='.","BinaryExpression","unexpected","no-useless-escape","Unnecessary escape character: \\..","Literal","unnecessaryEscape",["134","135"],["131"],["132"],"'useState' is defined but never used.","'InputLabel' is defined but never used.","'MenuItem' is defined but never used.","'Select' is defined but never used.","'FormControl' is defined but never used.","jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","JSXOpeningElement","no-global-assign","no-unsafe-negation",{"desc":"136","fix":"137"},{"messageId":"138","fix":"139","desc":"140"},{"messageId":"141","fix":"142","desc":"143"},"Update the dependencies array to be: [props.history, user_data.login]",{"range":"144","text":"145"},"removeEscape",{"range":"146","text":"147"},"Remove the `\\`. This maintains the current functionality.","escapeBackslash",{"range":"148","text":"149"},"Replace the `\\` with `\\\\` to include the actual backslash character.",[310,312],"[props.history, user_data.login]",[2533,2534],"",[2533,2533],"\\"]